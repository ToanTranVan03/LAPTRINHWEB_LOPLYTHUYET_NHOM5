@model TechShare.Models.ContactMessage

@{
    ViewData["Title"] = "Chi tiết tin nhắn";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-action="Manage" class="btn btn-outline-secondary mb-3">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>

            <div class="card-premium p-4 mb-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h4 class="fw-bold mb-1">@Model.Subject</h4>
                        <span class="text-muted small">Gửi lúc @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    @switch (Model.Status)
                    {
                        case TechShare.Models.ContactStatus.New:
                            <span class="badge-gradient-danger">Mới</span>
                            break;
                        case TechShare.Models.ContactStatus.Read:
                            <span class="badge-gradient-warning">Đã đọc</span>
                            break;
                        case TechShare.Models.ContactStatus.Replied:
                            <span class="badge-gradient-success">Đã trả lời</span>
                            break;
                    }
                </div>

                <hr />

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="fw-semibold small text-muted">Họ tên</div>
                        <div>@Model.FullName</div>
                    </div>
                    <div class="col-md-4">
                        <div class="fw-semibold small text-muted">Email</div>
                        <div><a href="mailto:@Model.Email">@Model.Email</a></div>
                    </div>
                    <div class="col-md-4">
                        <div class="fw-semibold small text-muted">Điện thoại</div>
                        <div><a href="tel:@Model.Phone">@Model.Phone</a></div>
                    </div>
                </div>

                <div class="bg-light rounded-3 p-3 mb-3">
                    <div class="fw-semibold small text-muted mb-2">Nội dung tin nhắn</div>
                    <p class="mb-0">@Model.Message</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.AdminReply))
                {
                    <div class="rounded-3 p-3" style="background: rgba(102,126,234,0.08); border-left: 4px solid var(--primary);">
                        <div class="fw-semibold small mb-2" style="color: var(--primary);">
                            <i class="bi bi-reply me-1"></i> Phản hồi từ Admin
                            <span class="text-muted ms-2">@Model.RepliedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <p class="mb-0">@Model.AdminReply</p>
                    </div>
                }
            </div>

            @if (Model.Status != TechShare.Models.ContactStatus.Replied)
            {
                <div class="card-premium p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-reply me-2" style="color:var(--primary);"></i>Phản hồi</h5>
                    <form asp-action="Reply" asp-route-id="@Model.Id" method="post" class="form-premium">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <textarea name="adminReply" class="form-control" rows="4" required placeholder="Nhập nội dung phản hồi..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-gradient">
                            <i class="bi bi-send me-1"></i> Gửi phản hồi
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
