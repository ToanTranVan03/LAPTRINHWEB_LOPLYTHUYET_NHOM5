@model TechShare.Models.Category

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="warning-card">
                <div class="warning-header">
                    <i class="bi bi-exclamation-triangle-fill fs-1 d-block mb-2"></i>
                    <h4 class="mb-1">Xác nhận xóa danh mục</h4>
                    <p class="mb-0 opacity-75">Các sản phẩm trong danh mục này có thể bị ảnh hưởng!</p>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="bg-light rounded-3 p-4 mb-4">
                        <i class="bi bi-tag-fill fs-2 mb-2" style="color: var(--primary);"></i>
                        <h4 class="fw-bold">@Model.Name</h4>
                    </div>
                    <form asp-action="Delete" class="d-flex gap-2">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-arrow-left me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-gradient-danger flex-fill">
                            <i class="bi bi-trash3 me-1"></i> Xóa danh mục
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
