@model IEnumerable<TechShare.Models.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="container py-4">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1 fw-bold"><i class="bi bi-tags me-2"></i> Quản lý Danh mục</h2>
                <p class="mb-0 opacity-75">Phân loại thiết bị cho thuê — @Model.Count() danh mục</p>
            </div>
            <a asp-action="Create" class="btn btn-light fw-bold">
                <i class="bi bi-plus-lg me-1"></i> Thêm danh mục
            </a>
        </div>
    </div>

    <!-- Category Stats Grid -->
    <div class="row g-3 mb-4">
        @{
            string[] gradients = { "bg-gradient-primary", "bg-gradient-success", "bg-gradient-warning", "bg-gradient-info", "bg-gradient-danger", "bg-gradient-dark" };
            string[] icons = { "bi-laptop", "bi-camera", "bi-headphones", "bi-controller", "bi-projector", "bi-tablet", "bi-phone", "bi-wifi" };
            int idx = 0;
        }
        @foreach (var cat in Model)
        {
            <div class="col-lg-3 col-md-4 col-6">
                <div class="stat-card @gradients[idx % gradients.Length] text-center">
                    <div class="stat-icon mx-auto"><i class="bi @icons[idx % icons.Length]"></i></div>
                    <div class="stat-value">@(cat.Products?.Count ?? 0)</div>
                    <div class="stat-label">@cat.Name</div>
                </div>
            </div>
            idx++;
        }
    </div>

    <!-- Category Table -->
    <div class="card-premium">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Tên danh mục</th>
                            <th class="text-center">Số sản phẩm</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <i class="bi bi-tag-fill me-2" style="color: var(--primary);"></i>
                                    <strong>@item.Name</strong>
                                </td>
                                <td class="text-center">
                                    <span class="badge-gradient-primary">
                                        @(item.Products?.Count ?? 0) sản phẩm
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-pencil me-1"></i> Sửa
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i> Chi tiết
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>