@model TechShare.ViewModels.UserProfileViewModel

@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex flex-column flex-md-row align-items-md-center gap-3 mb-4">
                        <img src="@Model.AvatarUrl"
                             onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName)&background=8A2BE2&color=fff&size=160&rounded=true&bold=true';"
                             class="rounded-circle border"
                             style="width: 92px; height: 92px; object-fit: cover;"
                             alt="Avatar" />
                        <div>
                            <h3 class="mb-1">@Model.FullName</h3>
                            <div class="text-muted">@Model.UserNameOrEmail</div>
                            @if (Model.IsVerified)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle mt-2">
                                    <i class="bi bi-patch-check-fill me-1"></i>Đã xác thực
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle mt-2">
                                    <i class="bi bi-shield-exclamation me-1"></i>Chưa xác thực
                                </span>
                            }
                        </div>
                    </div>

                    <hr />

                    <form asp-action="Profile" method="post" class="mt-3">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="FullName" class="form-label fw-semibold">Họ và tên</label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Email</label>
                                <input class="form-control" value="@Model.Email" readonly />
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="Address" class="form-label fw-semibold">Địa chỉ</label>
                                <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Vị trí hiện tại</label>
                                <div class="border rounded-3 p-3 bg-light-subtle">
                                    @if (Model.CurrentLatitude.HasValue && Model.CurrentLongitude.HasValue)
                                    {
                                        var lat = Model.CurrentLatitude.Value.ToString("0.000000", System.Globalization.CultureInfo.InvariantCulture);
                                        var lng = Model.CurrentLongitude.Value.ToString("0.000000", System.Globalization.CultureInfo.InvariantCulture);
                                        <div class="mb-1">Lat: @lat, Lng: @lng</div>
                                        <a href="https://www.google.com/maps?q=@lat,@lng" target="_blank" rel="noopener noreferrer">
                                            Xem trên Google Maps
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có vị trí. Hãy bật định vị để cập nhật.</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-gradient px-4">
                                <i class="bi bi-floppy me-1"></i> Lưu thông tin
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}