@{
    ViewData["Title"] = "Về chúng tôi";
}

<div class="container py-4">
    <div class="page-header mb-4">
        <h1 class="mb-1"><i class="bi bi-building me-2"></i>Về TechShare</h1>
        <p class="mb-0 opacity-75">Câu chuyện, sứ mệnh và đội ngũ của chúng tôi</p>
    </div>

    <!-- Mission -->
    <div class="row g-4 mb-5 align-items-center">
        <div class="col-lg-6 reveal">
            <span class="badge-gradient-primary mb-2 d-inline-block">Sứ mệnh</span>
            <h2 class="fw-bold mb-3">Chia sẻ công nghệ, kết nối cộng đồng</h2>
            <p class="text-muted" style="line-height: 1.8;">
                TechShare ra đời với mong muốn giúp mọi người tiếp cận các thiết bị công nghệ cao cấp
                mà không cần phải bỏ ra chi phí lớn để mua sắm. Chúng tôi tin rằng công nghệ nên được
                chia sẻ, và ai cũng xứng đáng được trải nghiệm những sản phẩm tốt nhất.
            </p>
            <p class="text-muted" style="line-height: 1.8;">
                Từ sinh viên cần laptop mạnh cho dự án, nhiếp ảnh gia cần thuê lens chuyên nghiệp, đến
                công ty cần thiết bị cho sự kiện — TechShare đều sẵn sàng phục vụ.
            </p>
        </div>
        <div class="col-lg-6 reveal">
            <div class="row g-3">
                <div class="col-6">
                    <div class="stat-card bg-gradient-primary h-100 text-center">
                        <div class="stat-value">1000+</div>
                        <div class="stat-label">Thiết bị cho thuê</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-card bg-gradient-success h-100 text-center">
                        <div class="stat-value">500+</div>
                        <div class="stat-label">Khách hàng hài lòng</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-card bg-gradient-info h-100 text-center">
                        <div class="stat-value">50+</div>
                        <div class="stat-label">Tỉnh thành phục vụ</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-card bg-gradient-warning h-100 text-center">
                        <div class="stat-value">4.8⭐</div>
                        <div class="stat-label">Đánh giá trung bình</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Values -->
    <div class="text-center mb-4">
        <span class="badge-gradient-info mb-2 d-inline-block">Giá trị cốt lõi</span>
        <h2 class="fw-bold mb-2">Những giá trị chúng tôi theo đuổi</h2>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-3 col-md-6 reveal">
            <div class="card-premium p-4 text-center h-100">
                <div class="mb-3" style="font-size: 2.5rem; color: var(--primary);"><i class="bi bi-gem"></i></div>
                <h5 class="fw-bold">Chất lượng</h5>
                <p class="text-muted small">Mỗi thiết bị đều được kiểm tra kỹ lưỡng trước khi cho thuê, đảm bảo hoạt động hoàn hảo.</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 reveal">
            <div class="card-premium p-4 text-center h-100">
                <div class="mb-3" style="font-size: 2.5rem; color: #11998e;"><i class="bi bi-people-fill"></i></div>
                <h5 class="fw-bold">Cộng đồng</h5>
                <p class="text-muted small">Xây dựng cộng đồng chia sẻ thiết bị văn minh, tin cậy và có trách nhiệm.</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 reveal">
            <div class="card-premium p-4 text-center h-100">
                <div class="mb-3" style="font-size: 2.5rem; color: #f2994a;"><i class="bi bi-lightning-charge-fill"></i></div>
                <h5 class="fw-bold">Nhanh chóng</h5>
                <p class="text-muted small">Quy trình thuê đơn giản, duyệt đơn nhanh, giao hàng kịp thời cho mọi nhu cầu.</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 reveal">
            <div class="card-premium p-4 text-center h-100">
                <div class="mb-3" style="font-size: 2.5rem; color: #eb3349;"><i class="bi bi-shield-lock-fill"></i></div>
                <h5 class="fw-bold">An toàn</h5>
                <p class="text-muted small">Bảo mật thông tin tuyệt đối, xác thực KYC và giám sát mọi giao dịch.</p>
            </div>
        </div>
    </div>

    <!-- Team -->
    <div class="text-center mb-4">
        <span class="badge-gradient-success mb-2 d-inline-block">Đội ngũ</span>
        <h2 class="fw-bold mb-2">Thành viên nhóm 5</h2>
        <p class="text-muted">Lớp Lập trình Web - Lý thuyết</p>
    </div>

    <div class="row g-4 mb-5 justify-content-center">
        <div class="col-lg-3 col-md-6 reveal">
            <div class="team-card text-center h-100">
                <div class="team-avatar">TĐ</div>
                <h6 class="fw-bold mt-3 mb-1">Trần Văn Đình</h6>
                <span class="badge-gradient-primary">Leader</span>
                <p class="text-muted small mt-2">Quản lý dự án, phát triển backend</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 reveal">
            <div class="team-card text-center h-100">
                <div class="team-avatar" style="background: var(--gradient-success);">TV</div>
                <h6 class="fw-bold mt-3 mb-1">Thành viên 2</h6>
                <span class="badge-gradient-info">Developer</span>
                <p class="text-muted small mt-2">Phát triển frontend, thiết kế UI</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 reveal">
            <div class="team-card text-center h-100">
                <div class="team-avatar" style="background: var(--gradient-warning);">TV</div>
                <h6 class="fw-bold mt-3 mb-1">Thành viên 3</h6>
                <span class="badge-gradient-info">Developer</span>
                <p class="text-muted small mt-2">Database, testing, tài liệu</p>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 reveal">
            <div class="team-card text-center h-100">
                <div class="team-avatar" style="background: var(--gradient-danger);">TV</div>
                <h6 class="fw-bold mt-3 mb-1">Thành viên 4</h6>
                <span class="badge-gradient-info">Developer</span>
                <p class="text-muted small mt-2">Chức năng, seed data, báo cáo</p>
            </div>
        </div>
    </div>
</div>
