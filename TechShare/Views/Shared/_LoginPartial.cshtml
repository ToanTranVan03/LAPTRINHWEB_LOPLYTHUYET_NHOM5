@using Microsoft.AspNetCore.Identity
@using TechShare.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        var userName = user?.UserName ?? user?.Email ?? "User";
        var firstLetter = userName.Substring(0, 1).ToUpper();
        var avatarUrl = $"/avatars/{user?.Id}.jpg?v={DateTime.Now.Ticks}";

        <li class="nav-item dropdown dropdown-premium ms-2">
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userAvatarMenu" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false" style="padding-top: 0.2rem; padding-bottom: 0.2rem;">
                <img src="@avatarUrl"
                     onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@firstLetter&background=8A2BE2&color=fff&size=100&rounded=true&bold=true';"
                     class="rounded-circle shadow-sm me-2"
                     style="width: 35px; height: 35px; object-fit: cover; border: 2px solid #fff;" alt="Avatar" />
                <span class="fw-medium text-dark">@userName</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userAvatarMenu">
                <li>
                    <a class="dropdown-item fw-semibold d-flex align-items-center" asp-controller="Home"
                           asp-action="Profile">
                        <i class="bi bi-person-vcard fs-5 me-2 text-primary"></i> Thông tin cá nhân
                    </a>
                </li>
                <li>
                    <a class="dropdown-item fw-semibold text-primary d-flex align-items-center" href="#"
                           data-bs-toggle="modal" data-bs-target="#avatarModal">
                        <i class="bi bi-camera fs-5 me-2"></i> Đổi ảnh đại diện
                    </a>
                </li>
                <li>
                    <a class="dropdown-item fw-semibold d-flex align-items-center" asp-controller="Chat"
                           asp-action="Index">
                        <i class="bi bi-chat-dots fs-5 me-2 text-primary"></i> Tin nhắn của tôi
                    </a>
                </li>
                
                <li>
                    <a class="dropdown-item fw-semibold d-flex align-items-center" asp-controller="MyProducts" asp-action="Index">
                        <i class="bi bi-box-seam fs-5 me-2 text-primary"></i> Thiết bị cho thuê của tôi
                    </a>
                </li>
                <li>
    <a class="dropdown-item fw-semibold d-flex align-items-center" asp-controller="Chat" asp-action="Index">
        <i class="bi bi-messenger fs-5 me-2 text-primary" style="color: #0084ff !important;"></i> Khung chat (P2P)
    </a>
</li>
                <li>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item text-danger fw-bold"><i
                            class="bi bi-box-arrow-right me-2"></i> Đăng xuất</button>
                        </form>
                    </li>
                </ul>
            </li>
        }
else
        {
            <li class="nav-item">
                <a class="nav-link btn btn-outline-primary rounded-pill px-3 me-2 fw-semibold" asp-area="Identity"
                       asp-page="/Account/Register">
                    <i class="bi bi-person-plus me-1"></i> Đăng ký
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link btn btn-primary text-white rounded-pill px-4 fw-bold shadow-sm" asp-area="Identity"
                       asp-page="/Account/Login"
                       style="background: linear-gradient(135deg, #8A2BE2 0%, #4B0082 100%); border: none;">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                </a>
            </li>
        }
    </ul>
