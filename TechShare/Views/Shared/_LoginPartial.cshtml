@using Microsoft.AspNetCore.Identity
@using TechShare.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item d-flex align-items-center">
        <span class="user-avatar">
            @(User.Identity?.Name?.Substring(0, 1).ToUpper())
        </span>
        <a class="nav-link nav-link-custom py-0" asp-area="Identity" asp-page="/Account/Manage/Index">
            @User.Identity?.Name
        </a>
    </li>
    <li class="nav-item">
        <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-auth-outline btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-auth-outline btn-sm" asp-area="Identity" asp-page="/Account/Register">
            <i class="bi bi-person-plus me-1"></i> Đăng ký
        </a>
    </li>
    <li class="nav-item">
        <a class="btn btn-auth btn-sm" asp-area="Identity" asp-page="/Account/Login">
            <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
        </a>
    </li>
}
</ul>