<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="TechShare - Nền tảng chia sẻ và cho thuê thiết bị công nghệ hàng đầu Việt Nam" />
    <title>@ViewData["Title"] - TechShare</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TechShare.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-glass fixed-top">
            <div class="container">
                <a class="navbar-brand navbar-brand-logo" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-share-fill me-1"></i> TechShare
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-heart me-1"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(currentController == "Products" && currentAction == "Index" ? "active" : "")" asp-controller="Products" asp-action="Index">
                                <i class="bi bi-grid me-1"></i> Sản phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(currentController == "Marketplace" ? "active" : "")" asp-controller="Marketplace" asp-action="Index">
                                <i class="bi bi-shop me-1"></i> Thanh lý
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(currentController == "Home" && currentAction == "About" ? "active" : "")" asp-controller="Home" asp-action="About">
                                <i class="bi bi-building me-1"></i> Về chúng tôi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(currentController == "Home" && currentAction == "FAQ" ? "active" : "")" asp-controller="Home" asp-action="FAQ">
                                <i class="bi bi-question-circle me-1"></i> FAQ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(currentController == "Contact" && currentAction == "Index" ? "active" : "")" asp-controller="Contact" asp-action="Index">
                                <i class="bi bi-headset me-1"></i> Liên hệ
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown dropdown-premium">
                                <a class="nav-link nav-link-custom dropdown-toggle" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock me-1"></i> Quản trị
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="adminMenu">
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags me-2"></i>Danh mục</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="Manage"><i class="bi bi-box-seam me-2"></i>Sản phẩm</a></li>
                                    <li><a class="dropdown-item" asp-controller="Bookings" asp-action="Index"><i class="bi bi-calendar-check me-2"></i>Đặt lịch</a></li>
                                    <li><a class="dropdown-item" asp-controller="Contact" asp-action="Manage"><i class="bi bi-envelope-open me-2"></i>Tin nhắn</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown dropdown-premium">
                                <a class="nav-link nav-link-custom dropdown-toggle" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i> Cá nhân
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="userMenu">
                                    <li>
                                        <a class="dropdown-item @(currentController == "Bookings" && currentAction == "MyBookings" ? "active" : "")" asp-controller="Bookings" asp-action="MyBookings">
                                            <i class="bi bi-bag-check me-2"></i> Đơn thuê của tôi
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(currentController == "Products" && currentAction == "MyProducts" ? "active" : "")" asp-controller="Products" asp-action="MyProducts">
                                            <i class="bi bi-box-arrow-up-right me-2"></i> Thiết bị cho thuê 
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(currentController == "Marketplace" && currentAction == "MyListings" ? "active" : "")" asp-controller="Marketplace" asp-action="MyListings">
                                            <i class="bi bi-shop-window me-2"></i> Thiết bị thanh lý
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item @(currentController == "Wishlist" ? "active" : "")" asp-controller="Wishlist" asp-action="Index">
                                            <i class="bi bi-heart me-2"></i> Yêu thích
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="content-wrapper" style="margin-top: 76px;">
        <main role="main">
            @if (TempData["Message"] != null)
            {
                <div class="container mt-3">
                    <div class="alert alert-toast alert-info alert-dismissible fade show" role="alert">
                        <i class="bi bi-info-circle me-2"></i> @TempData["Message"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="footer-premium">
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-4 col-md-12 pe-lg-5">
                    <h4 class="footer-brand mb-3"><i class="bi bi-share-fill"></i> TechShare</h4>
                    <p style="color: rgba(255,255,255,0.6); line-height: 1.8;">
                        Nền tảng chia sẻ và cho thuê thiết bị công nghệ hàng đầu.
                        Trải nghiệm sản phẩm đỉnh cao với chi phí tiết kiệm nhất.
                    </p>
                    <div class="footer-social d-flex gap-2 mt-3">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                        <a href="#"><i class="bi bi-github"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="text-white fw-bold mb-3">Khám phá</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li><a asp-controller="Products" asp-action="Index" class="footer-link">Sản phẩm</a></li>
                        <li><a asp-controller="Home" asp-action="About" class="footer-link">Về chúng tôi</a></li>
                        <li><a asp-controller="Home" asp-action="FAQ" class="footer-link">Câu hỏi thường gặp</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="text-white fw-bold mb-3">Chính sách</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li><a asp-controller="Home" asp-action="Privacy" class="footer-link">Bảo mật</a></li>
                        <li><a asp-controller="Contact" asp-action="Index" class="footer-link">Hỗ trợ</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h6 class="text-white fw-bold mb-3">Liên hệ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2" style="color: rgba(255,255,255,0.6);">
                        <li><i class="bi bi-geo-alt me-2" style="color: var(--primary);"></i> Nam Định, Việt Nam</li>
                        <li><i class="bi bi-envelope me-2" style="color: var(--primary);"></i> contact@techshare.com</li>
                        <li><i class="bi bi-telephone me-2" style="color: var(--primary);"></i> +84 123 456 789</li>
                    </ul>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.1);" class="mt-4 mb-3" />
            <div class="text-center small" style="color: rgba(255,255,255,0.4);">
                &copy; 2026 TechShare Platform. Bản quyền thuộc về Trần Văn Đình.
            </div>
        </div>
    </footer>

    <button id="backToTop" class="back-to-top" title="Lên đầu trang">
        <i class="bi bi-chevron-up"></i>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
