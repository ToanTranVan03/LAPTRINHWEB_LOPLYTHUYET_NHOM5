<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechShare</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TechShare.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        body {
            display: flex;
            flex-direction: column;
            margin-bottom: 0 !important; /* Xóa khoảng trắng mặc định của ASP.NET */
            background-color: #f8f9fa; /* Nền xám nhạt */
            font-family: 'Inter', sans-serif;
        }
        .content-wrapper {
            flex: 1 0 auto; /* Tự động đẩy phần nội dung dài ra để dồn footer xuống đáy */
        }
        .custom-footer {
            flex-shrink: 0;
            position: relative !important; /* Xóa lỗi lơ lửng của footer cũ */
            width: 100%;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm py-3 mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-primary fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-share-fill me-1"></i> TechShare
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 fw-medium">
                        <li class="nav-item">
                            <a class="nav-link text-dark px-3 hover-primary" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-danger fw-bold px-3" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock"></i> Quản trị
                                </a>
                                <ul class="dropdown-menu shadow border-0" aria-labelledby="adminMenu">
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="Dashboard"><i class="bi bi-graph-up me-2"></i>Thống kê</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Quản lý Danh mục</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">Quản lý Sản phẩm</a></li>
                                    <li><a class="dropdown-item" asp-controller="Bookings" asp-action="Index">Quản lý Đặt lịch</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold px-3" asp-controller="Bookings" asp-action="MyBookings">
                                    <i class="bi bi-box-seam me-1"></i> Đơn hàng của tôi
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="content-wrapper">
        <div class="container">
            <main role="main" class="pb-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="bg-dark text-light py-5 custom-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-5 col-md-12 pe-lg-5">
                    <h4 class="fw-bold text-primary mb-3"><i class="bi bi-share-fill"></i> TechShare</h4>
                    <p class="text-muted" style="line-height: 1.8;">
                        Nền tảng chia sẻ và cho thuê thiết bị công nghệ hàng đầu. Giúp bạn trải nghiệm các sản phẩm đỉnh cao với chi phí tiết kiệm nhất.
                    </p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="text-light fs-5"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-light fs-5"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="text-light fs-5"><i class="bi bi-github"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3 text-white">Chính sách</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li><a href="/" class="text-decoration-none text-muted custom-link">Về chúng tôi</a></li>
                        <li><a href="/" class="text-decoration-none text-muted custom-link">Quy định thuê đồ</a></li>
                        <li><a href="/Home/Privacy" class="text-decoration-none text-muted custom-link">Chính sách bảo mật</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3 text-white">Liên hệ trực tiếp</h5>
                    <ul class="list-unstyled d-flex flex-column gap-3 text-muted">
                        <li><i class="bi bi-geo-alt text-primary me-2"></i> Nam Định, Việt Nam</li>
                        <li><i class="bi bi-envelope text-primary me-2"></i> contact@techshare.com</li>
                        <li><i class="bi bi-telephone text-primary me-2"></i> +84 123 456 789</li>
                    </ul>
                </div>
            </div>
            
            <hr class="border-secondary mt-5 mb-4" />
            
            <div class="text-center text-muted small">
                &copy; 2026 - TechShare Platform. Bản quyền thuộc về Trần Văn Đình.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>