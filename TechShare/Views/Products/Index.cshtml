@model TechShare.ViewModels.ProductCatalogViewModel

@{
    ViewData["Title"] = "Sản phẩm";
    var currentSort = Model.SortOrder;
}

<div class="hero-section">
    <div class="container text-center position-relative" style="z-index: 1;">
        <h1 class="hero-title mb-3">
            Trang sản phẩm
            <br />
            <span style="color: rgba(255,255,255,0.85); font-weight: 400;">tìm kiếm, lọc và đặt thuê ngay</span>
        </h1>
        <p class="hero-subtitle mb-4">Toàn bộ thiết bị đã được tách khỏi trang chủ để bạn duyệt nhanh hơn theo nhu cầu thực tế.</p>

        <div class="search-glass mx-auto" style="max-width: 820px;">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-md-5 position-relative">
                    <input asp-for="SearchString" class="form-control" id="search-input" placeholder="Tìm thiết bị, hãng, mô tả..." autocomplete="off" />
                    <div id="search-suggestions" class="dropdown-menu w-100 shadow-sm" style="display:none; position:absolute; top: 100%; z-index: 1000; border-radius: 0.5rem; border: none; padding: 0.5rem 0;">
                    </div>
                </div>
                <div class="col-md-4">
                    <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories">
                        <option value="">-- Tất cả danh mục --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-light w-100 fw-bold">
                        <i class="bi bi-search me-1"></i> Tìm kiếm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <p class="text-muted mb-0">
            <i class="bi bi-grid me-1"></i> Hiển thị <strong>@Model.Products.Count</strong> / <strong>@Model.TotalItems</strong> sản phẩm
        </p>
        <div class="sort-pills d-flex gap-1 flex-wrap">
            <a href="@Url.Action("Index", new { searchString = Model.SearchString, categoryId = Model.CategoryId, sortOrder = "newest", page = 1 })"
               class="btn btn-sm @(currentSort == "newest" || currentSort == null ? "active" : "")">Mới nhất</a>
            <a href="@Url.Action("Index", new { searchString = Model.SearchString, categoryId = Model.CategoryId, sortOrder = "price_asc", page = 1 })"
               class="btn btn-sm @(currentSort == "price_asc" ? "active" : "")">Giá tăng</a>
            <a href="@Url.Action("Index", new { searchString = Model.SearchString, categoryId = Model.CategoryId, sortOrder = "price_desc", page = 1 })"
               class="btn btn-sm @(currentSort == "price_desc" ? "active" : "")">Giá giảm</a>
            <a href="@Url.Action("Index", new { searchString = Model.SearchString, categoryId = Model.CategoryId, sortOrder = "rating", page = 1 })"
               class="btn btn-sm @(currentSort == "rating" ? "active" : "")">Đánh giá</a>
        </div>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-search"></i></div>
            <h5>Không tìm thấy sản phẩm phù hợp</h5>
            <p class="text-muted">Thử đổi từ khóa, danh mục hoặc thứ tự sắp xếp.</p>
            <a asp-action="Index" class="btn btn-gradient mt-2">Xem toàn bộ sản phẩm</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Products)
            {
                var avgRating = item.Reviews != null && item.Reviews.Any() ? item.Reviews.Average(r => r.Rating) : 0;
                var reviewCount = item.Reviews?.Count ?? 0;

                <div class="col-lg-4 col-md-6 reveal">
                    <div class="product-card card">
                        <div class="card-img-wrapper">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/400x250?text=No+Image" : item.ImageUrl)"
                                 class="card-img-top" alt="@item.Name">
                            <div class="card-img-overlay-badge">
                                <span class="price-badge">@item.PricePerDay.ToString("N0") đ/ngày</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <h5 class="card-title mb-0">@item.Name</h5>
                                <span class="badge-gradient-info">@item.Category?.Name</span>
                            </div>
                            <p class="card-text">@item.Description</p>

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                    <span class="text-muted ms-1 small">(@reviewCount)</span>
                                </div>
                                <span class="small">
                                    <span class="availability-dot @(item.IsAvailable ? "available" : "unavailable")"></span>
                                    @(item.IsAvailable ? "Sẵn sàng" : "Đang bận")
                                </span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between text-muted small mb-3">
                                <div><i class="bi bi-geo-alt me-1"></i> @item.Location</div>
                                @if (item.DistanceKm.HasValue)
                                {
                                    <div class="badge bg-light text-dark shadow-sm border"><i class="bi bi-cursor-fill text-primary"></i> Cách @item.DistanceKm.Value km</div>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 p-3 pt-0">
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary w-100">
                                    <i class="bi bi-eye me-1"></i> Chi tiết
                                </a>
                                @if (item.IsAvailable)
                                {
                                    <a asp-controller="Bookings" asp-action="Create" asp-route-productId="@item.Id" class="btn btn-gradient-success w-100">
                                        <i class="bi bi-bag-plus me-1"></i> Thuê ngay
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary w-100" disabled>
                                        <i class="bi bi-clock me-1"></i> Đang cho thuê
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5 d-flex justify-content-center">
                <ul class="pagination pagination-premium">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchString = Model.SearchString, categoryId = Model.CategoryId, sortOrder = Model.SortOrder, page = Model.CurrentPage - 1 })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { searchString = Model.SearchString, categoryId = Model.CategoryId, sortOrder = Model.SortOrder, page = i })">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchString = Model.SearchString, categoryId = Model.CategoryId, sortOrder = Model.SortOrder, page = Model.CurrentPage + 1 })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let timeout = null;
            $('#search-input').on('input', function () {
                clearTimeout(timeout);
                const query = $(this).val();
                if (query.length < 2) {
                    $('#search-suggestions').hide();
                    return;
                }

                timeout = setTimeout(function () {
                    $.get('/api/products/search-suggestions', { query: query }, function (data) {
                        const container = $('#search-suggestions');
                        container.empty();

                        if (data && data.length > 0) {
                            data.forEach(function (item) {
                                const priceText = item.price.toLocaleString('vi-VN') + ' đ/ngày';
                                const html = `
                                    <a href="/Products/Details/${item.id}" class="dropdown-item d-flex align-items-center py-2" style="gap: 10px; white-space: normal;">
                                        <img src="${item.image ?? 'https://via.placeholder.com/50'}" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" />
                                        <div>
                                            <div class="fw-bold" style="font-size: 0.9rem;">${item.name}</div>
                                            <div class="text-primary small">${priceText}</div>
                                        </div>
                                    </a>
                                `;
                                container.append(html);
                            });
                            container.show();
                        } else {
                            container.append('<div class="dropdown-item text-muted disabled">Không tìm thấy kết quả</div>');
                            container.show();
                        }
                    });
                }, 300); // 300ms debounce
            });

            // Ẩn gợi ý khi click ra ngoài
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.search-glass').length) {
                    $('#search-suggestions').hide();
                }
            });
        });
    </script>
}
