@model IEnumerable<TechShare.Models.Product>

@{
    ViewData["Title"] = "Thiết bị cho thuê của tôi";
}

<div class="container py-4">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h1 class="mb-1"><i class="bi bi-box-arrow-up-right me-2"></i>Thiết bị cho thuê của tôi</h1>
                <p class="mb-0 opacity-75">Quản lý các thiết bị công nghệ bạn đang đăng cho thuê</p>
            </div>
            <div>
                <a asp-action="Create" class="btn btn-light btn-lg fw-bold">
                    <i class="bi bi-plus-circle me-1"></i> Đăng thiết bị cho thuê
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
            <h5>Bạn chưa đăng thiết bị nào cho thuê</h5>
            <p class="text-muted">Kiếm thêm thu nhập bằng cách cho thuê các thiết bị công nghệ không sử dụng thường xuyên!</p>
            <a asp-action="Create" class="btn btn-gradient">
                <i class="bi bi-plus-circle me-1"></i> Đăng cho thuê ngay
            </a>
        </div>
    }
    else
    {
        <div class="card card-premium overflow-hidden">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Sản phẩm</th>
                            <th>Giá thuê / ngày</th>
                            <th>Danh mục</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="flex-shrink-0" style="width: 60px; height: 60px;">
                                            <img src="@item.ImageUrl" class="w-100 h-100 rounded object-fit-cover" alt="@item.Name" />
                                        </div>
                                        <div>
                                            <h6 class="mb-1">
                                                <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none fw-bold">
                                                    @item.Name
                                                </a>
                                            </h6>
                                            <div class="small text-muted"><i class="bi bi-geo-alt me-1"></i> @item.Location</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold" style="color: var(--primary);">@item.PricePerDay.ToString("N0")đ</span>
                                </td>
                                <td>
                                    <span class="badge-gradient-info">@item.Category?.Name</span>
                                </td>
                                <td>
                                    @if(item.IsAvailable)
                                    {
                                        <span class="badge bg-success">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Tạm ẩn</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Xem">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
