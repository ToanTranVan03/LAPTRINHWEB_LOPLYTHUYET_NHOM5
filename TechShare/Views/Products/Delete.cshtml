@model TechShare.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="warning-card">
                <div class="warning-header">
                    <i class="bi bi-exclamation-triangle-fill fs-1 d-block mb-2"></i>
                    <h4 class="mb-1">Xác nhận xóa sản phẩm</h4>
                    <p class="mb-0 opacity-75">Hành động này không thể hoàn tác.</p>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/100" : Model.ImageUrl)"
                             class="rounded-3 me-3" style="width: 80px; height: 80px; object-fit: cover;" />
                        <div>
                            <h5 class="fw-bold mb-1">@Model.Name</h5>
                            <span class="badge-gradient-info">@Model.Category?.Name</span>
                            <span class="badge-gradient-primary ms-1">@Model.PricePerDay.ToString("N0") đ/ngày</span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <small class="text-muted">Mô tả</small>
                            <p class="mb-0">@(Model.Description ?? "Không có")</p>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">Vị trí</small>
                            <p class="mb-0">@Model.Location</p>
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex gap-2">
                        <input type="hidden" asp-for="Id" />
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Manage" class="btn btn-outline-secondary flex-fill">
                                <i class="bi bi-arrow-left me-1"></i> Về quản trị
                            </a>
                        }
                        else
                        {
                            <a asp-action="MyProducts" class="btn btn-outline-secondary flex-fill">
                                <i class="bi bi-arrow-left me-1"></i> Hủy
                            </a>
                        }
                        <button type="submit" class="btn btn-gradient-danger flex-fill">
                            <i class="bi bi-trash3 me-1"></i> Xóa sản phẩm
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
