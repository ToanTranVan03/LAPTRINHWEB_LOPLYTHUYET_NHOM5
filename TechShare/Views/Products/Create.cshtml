@model TechShare.Models.Product

@{
    ViewData["Title"] = "Đăng sản phẩm cho thuê";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card-premium">
                <div class="card-header-gradient text-center">
                    <h4 class="mb-0"><i class="bi bi-cloud-arrow-up me-2"></i> Đăng sản phẩm cho thuê</h4>
                </div>
                <div class="card-body p-4 form-premium">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-7">
                                <label asp-for="Name" class="form-label">
                                    <i class="bi bi-laptop me-1"></i> Tên thiết bị
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="VD: MacBook Pro 16&quot; M3 Max..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-5">
                                <label asp-for="CategoryId" class="form-label">
                                    <i class="bi bi-tag me-1"></i> Danh mục
                                </label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">
                                <i class="bi bi-card-text me-1"></i> Mô tả chi tiết
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Tình trạng máy, cấu hình, phụ kiện đi kèm..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="PricePerDay" class="form-label">
                                    <i class="bi bi-cash me-1"></i> Giá thuê / ngày
                                </label>
                                <div class="input-group">
                                    <input asp-for="PricePerDay" class="form-control" type="number" min="0" placeholder="100000" />
                                    <span class="input-group-text fw-bold">đ</span>
                                </div>
                                <span asp-validation-for="PricePerDay" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Location" class="form-label">
                                    <i class="bi bi-geo-alt me-1"></i> Vị trí / Khu vực
                                </label>
                                <div class="input-group">
                                    <input asp-for="Location" id="locationInput" class="form-control" placeholder="VD: Hà Nội - Cầu Giấy" />
                                    <button type="button" class="btn btn-outline-secondary" id="btnGetLocation" title="Lấy tọa độ hiện tại">
                                        <i class="bi bi-crosshair"></i>
                                    </button>
                                </div>
                                <input type="hidden" asp-for="Latitude" id="latInput" />
                                <input type="hidden" asp-for="Longitude" id="lngInput" />
                                <span asp-validation-for="Location" class="text-danger small"></span>
                                <div id="locationDetailPanel" class="border rounded-3 p-2 mt-2 bg-light-subtle small" style="display:none;">
                                    <div class="fw-semibold text-dark mb-1">Chi tiết vị trí</div>
                                    <div id="locationDetailSummary" class="text-dark"></div>
                                    <div id="locationDetailAddress" class="text-muted"></div>
                                    <div id="locationDetailMeta" class="text-muted"></div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="bi bi-image me-1"></i> Ảnh sản phẩm
                            </label>
                            <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
                            <small class="text-muted">Tải ảnh từ máy tính của bạn.</small>
                            <div class="mt-2 text-center" id="imagePreviewWrapper" style="display:none;">
                                <img id="imagePreview" src="#" class="rounded-3 img-thumbnail" style="max-height: 200px; object-fit:cover;" />
                            </div>
                        </div>

                        <div class="bg-light rounded-3 p-3 mb-4 d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="mb-0 fw-bold">Trạng thái sẵn sàng cho thuê</h6>
                                <small class="text-muted">Bật để hiển thị sản phẩm ngay trên catalog công khai.</small>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" role="switch" style="width:3rem;height:1.5rem;" checked />
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Manage" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Về quản trị</a>
                            }
                            else
                            {
                                <a asp-action="MyProducts" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Hủy</a>
                            }
                            <button type="submit" class="btn btn-gradient px-4">
                                <i class="bi bi-cloud-arrow-up me-1"></i> Đăng sản phẩm
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('imageFile')?.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (ev) => {
                    document.getElementById('imagePreview').src = ev.target.result;
                    document.getElementById('imagePreviewWrapper').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });

        // Xử lý nút Lấy vị trí
        const btnGetLocation = document.getElementById('btnGetLocation');
        const locationInput = document.getElementById('locationInput');
        const latInput = document.getElementById('latInput');
        const lngInput = document.getElementById('lngInput');
        const locationDetailPanel = document.getElementById('locationDetailPanel');
        const locationDetailSummary = document.getElementById('locationDetailSummary');
        const locationDetailAddress = document.getElementById('locationDetailAddress');
        const locationDetailMeta = document.getElementById('locationDetailMeta');

        const setLoading = (isLoading) => {
            if (!btnGetLocation) return;
            btnGetLocation.disabled = isLoading;
            btnGetLocation.innerHTML = isLoading
                ? '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>'
                : '<i class="bi bi-crosshair"></i>';
        };

        const setCoordinates = (lat, lng) => {
            if (latInput) latInput.value = lat;
            if (lngInput) lngInput.value = lng;
        };

        const renderLocationDetail = ({ lat, lng, accuracy, source, shortArea, fullAddress }) => {
            if (!locationDetailPanel) return;

            const latText = Number.isFinite(Number(lat)) ? Number(lat).toFixed(6) : "-";
            const lngText = Number.isFinite(Number(lng)) ? Number(lng).toFixed(6) : "-";
            const accuracyText = Number.isFinite(Number(accuracy))
                ? `Độ chính xác ~${Math.round(Number(accuracy))}m`
                : "Độ chính xác: không xác định";

            if (locationDetailSummary) {
                locationDetailSummary.textContent = shortArea || fullAddress || "Đã lấy vị trí";
            }
            if (locationDetailAddress) {
                locationDetailAddress.textContent = fullAddress ? `Địa chỉ đầy đủ: ${fullAddress}` : "";
            }
            if (locationDetailMeta) {
                locationDetailMeta.textContent = `Lat: ${latText}, Lng: ${lngText} | ${accuracyText} | Nguồn: ${source} | Lúc: ${new Date().toLocaleString("vi-VN")}`;
            }

            locationDetailPanel.style.display = "block";
        };

        const getCurrentPosition = (options) => {
            return new Promise((resolve, reject) => {
                navigator.geolocation.getCurrentPosition(resolve, reject, options);
            });
        };

        const reverseGeocode = async (lat, lng) => {
            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&addressdetails=1&zoom=18&lat=${lat}&lon=${lng}`, {
                    headers: { "Accept-Language": "vi,en" }
                });

                if (!response.ok) return null;

                const data = await response.json();
                const address = data?.address;

                const cityPart = address?.city || address?.town || address?.state;
                const districtPart = address?.city_district || address?.suburb || address?.county || address?.state_district;
                const shortArea = [districtPart, cityPart]
                    .filter(part => !!part)
                    .join(", ")
                    || cityPart
                    || data?.display_name
                    || null;

                return {
                    shortArea,
                    fullAddress: data?.display_name || shortArea || null
                };
            } catch {
                return null;
            }
        };

        const getLocationFromIp = async () => {
            // Prefer same-origin endpoint to avoid browser CORS/ad-block issues.
            try {
                const localResponse = await fetch("/api/location/fallback", { cache: "no-store" });
                if (localResponse.ok) {
                    const data = await localResponse.json();
                    const lat = Number(data?.lat);
                    const lng = Number(data?.lng);
                    if (Number.isFinite(lat) && Number.isFinite(lng)) {
                        return { lat, lng, area: data?.area || null };
                    }
                }
            } catch {
                // Continue to direct providers
            }

            const providers = [
                {
                    url: "https://ipapi.co/json/",
                    parse: (data) => ({ lat: data?.latitude, lng: data?.longitude, area: data?.city || data?.region })
                },
                {
                    url: "https://ipwho.is/",
                    parse: (data) => ({ lat: data?.latitude, lng: data?.longitude, area: data?.city || data?.region })
                }
            ];

            for (const provider of providers) {
                try {
                    const response = await fetch(provider.url);
                    if (!response.ok) continue;
                    const data = await response.json();
                    const parsed = provider.parse(data);
                    const lat = Number(parsed.lat);
                    const lng = Number(parsed.lng);

                    if (Number.isFinite(lat) && Number.isFinite(lng)) {
                        return { lat, lng, area: parsed.area || null };
                    }
                } catch {
                    // Try next provider
                }
            }

            return null;
        };

        const tryGetBrowserLocation = async () => {
            try {
                return await getCurrentPosition({ enableHighAccuracy: true, timeout: 20000, maximumAge: 0 });
            } catch (error) {
                // Retry with less strict options and longer timeout if browser cannot lock quickly.
                if (error?.code === 2 || error?.code === 3) {
                    return await getCurrentPosition({ enableHighAccuracy: false, timeout: 35000, maximumAge: 0 });
                }
                throw error;
            }
        };

        btnGetLocation?.addEventListener('click', async function () {
            if (!("geolocation" in navigator)) {
                alert("Trình duyệt không hỗ trợ Geolocation.");
                return;
            }

            if (!window.isSecureContext && location.hostname !== "localhost" && location.hostname !== "127.0.0.1") {
                alert("Geolocation chỉ hoạt động trên HTTPS hoặc localhost.");
                return;
            }

            setLoading(true);

            try {
                const position = await tryGetBrowserLocation();
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                const accuracyMeters = Number(position.coords.accuracy);

                if (Number.isFinite(accuracyMeters) && accuracyMeters > 1200) {
                    const keepCoarseLocation = confirm(`GPS đang có độ chính xác thấp (~${Math.round(accuracyMeters)}m).\nBạn có muốn dùng vị trí này không?`);
                    if (!keepCoarseLocation) {
                        alert("Đã bỏ qua vị trí GPS chưa chính xác. Hãy thử lại hoặc nhập tay.");
                        return;
                    }
                }

                setCoordinates(lat, lng);

                const areaName = await reverseGeocode(lat, lng);
                if (locationInput) {
                    locationInput.value = areaName?.shortArea || areaName?.fullAddress || `Đã lấy tọa độ (${lat.toFixed(4)}, ${lng.toFixed(4)})`;
                }

                renderLocationDetail({
                    lat,
                    lng,
                    accuracy: accuracyMeters,
                    source: "GPS",
                    shortArea: areaName?.shortArea || null,
                    fullAddress: areaName?.fullAddress || null
                });
                return;
            } catch (error) {
                console.error("Geolocation failed:", error);

                if (error?.code === 1) {
                    alert("Trình duyệt đang chặn quyền vị trí. Hãy cho phép location cho site này.");
                    return;
                }

                const ipLocation = await getLocationFromIp();
                if (ipLocation) {
                    const areaName = ipLocation.area || `Vị trí gần đúng theo IP (${ipLocation.lat.toFixed(4)}, ${ipLocation.lng.toFixed(4)})`;
                    const accepted = confirm(`Không lấy được GPS chính xác.\nBạn có muốn dùng vị trí gần đúng theo IP: ${areaName} ?`);
                    if (accepted) {
                        setCoordinates(ipLocation.lat, ipLocation.lng);
                        if (locationInput) {
                            locationInput.value = areaName;
                        }
                        renderLocationDetail({
                            lat: ipLocation.lat,
                            lng: ipLocation.lng,
                            accuracy: null,
                            source: "IP",
                            shortArea: areaName,
                            fullAddress: areaName
                        });
                        alert("Đã dùng vị trí gần đúng theo IP.");
                    } else {
                        alert("Chưa điền vị trí tự động. Bạn có thể bấm lại để lấy GPS hoặc nhập tay.");
                    }
                    return;
                }

                const reason = error?.code === 2
                    ? "Thiết bị không xác định được vị trí hiện tại."
                    : error?.code === 3
                        ? "Yêu cầu lấy vị trí bị timeout."
                        : "Không thể lấy vị trí lúc này.";

                alert(`${reason} Thử lại sau hoặc nhập khu vực thủ công.`);
            } finally {
                setLoading(false);
            }
        });
    </script>
}

