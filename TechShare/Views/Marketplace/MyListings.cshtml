@model IEnumerable<TechShare.Models.MarketplaceListing>

@{
    ViewData["Title"] = "Tin rao bán của tôi";
}

<div class="container py-4">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h1 class="mb-1"><i class="bi bi-list-ul me-2"></i>Tin rao bán của tôi</h1>
                <p class="mb-0 opacity-75">Quản lý các thiết bị bạn đang đăng bán thanh lý</p>
            </div>
            <div>
                <a asp-action="Create" class="btn btn-light btn-lg fw-bold">
                    <i class="bi bi-plus-circle me-1"></i> Đăng tin mới
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
            <h5>Bạn chưa đăng bán thiết bị nào</h5>
            <p class="text-muted">Đăng bán các thiết bị công nghệ cũ không dùng đến ngay!</p>
            <a asp-action="Create" class="btn btn-gradient">
                <i class="bi bi-plus-circle me-1"></i> Đăng bán ngay
            </a>
        </div>
    }
    else
    {
        <div class="card card-premium overflow-hidden">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Sản phẩm</th>
                            <th>Giá bán</th>
                            <th>Ngày đăng</th>
                            <th>Tình trạng</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var conditionText = item.Condition switch
                            {
                                TechShare.Models.ProductCondition.LikeNew => "Như mới",
                                TechShare.Models.ProductCondition.Good => "Tốt",
                                TechShare.Models.ProductCondition.Fair => "Khá",
                                TechShare.Models.ProductCondition.Poor => "Cũ",
                                _ => "N/A"
                            };
                            
                            var statusBadge = item.Status switch
                            {
                                TechShare.Models.ListingStatus.Active => "badge bg-success",
                                TechShare.Models.ListingStatus.Sold => "badge bg-secondary",
                                TechShare.Models.ListingStatus.Cancelled => "badge bg-danger",
                                _ => "badge bg-secondary"
                            };

                            var statusText = item.Status switch
                            {
                                TechShare.Models.ListingStatus.Active => "Đang bán",
                                TechShare.Models.ListingStatus.Sold => "Đã bán",
                                TechShare.Models.ListingStatus.Cancelled => "Đã hủy",
                                _ => "N/A"
                            };

                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="flex-shrink-0" style="width: 60px; height: 60px;">
                                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/60x60?text=No+Img" : item.ImageUrl)"
                                                 class="w-100 h-100 rounded object-fit-cover" alt="@item.Title" />
                                        </div>
                                        <div>
                                            <h6 class="mb-1">
                                                <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none fw-bold">
                                                    @item.Title
                                                </a>
                                            </h6>
                                            <span class="badge-gradient-info" style="font-size: 0.75rem;">@item.Category?.Name</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold" style="color: var(--primary);">@item.Price.ToString("N0")đ</span>
                                </td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>@conditionText</td>
                                <td><span class="@statusBadge">@statusText</span></td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (item.Status == TechShare.Models.ListingStatus.Active)
                                        {
                                            <form asp-action="MarkSold" asp-route-id="@item.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Bạn chắc chắn muốn đánh dấu đã bán?');">
                                                <button type="submit" class="btn btn-sm btn-success" title="Đánh dấu đã bán">
                                                    <i class="bi bi-check-circle"></i> Đã bán
                                                </button>
                                            </form>
                                            
                                            <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Bạn chắc chắn muốn hủy tin rao này?');">
                                                <button type="submit" class="btn btn-sm btn-warning" title="Hủy tin rao">
                                                    <i class="bi bi-x-circle"></i> Hủy
                                                </button>
                                            </form>
                                        }

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('BẠN CÓ CHẮC CHẮN MUỐN XÓA TIN RAO NÀY?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
