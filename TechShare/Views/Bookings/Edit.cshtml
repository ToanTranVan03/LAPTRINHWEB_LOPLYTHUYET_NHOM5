@model TechShare.Models.Booking

@{
    ViewData["Title"] = "Chỉnh sửa đơn hàng";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card-premium">
                <div class="card-header-gradient text-center" style="background: var(--gradient-warning);">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i> Chỉnh sửa đơn hàng #@Model.Id</h4>
                </div>
                <div class="card-body p-4 form-premium">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="BookingDate" class="form-label">Ngày đặt</label>
                                <input asp-for="BookingDate" class="form-control" />
                                <span asp-validation-for="BookingDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label">Trạng thái</label>
                                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<TechShare.Models.BookingStatus>()"></select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label">Ngày nhận</label>
                                <input asp-for="StartDate" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label">Ngày trả</label>
                                <input asp-for="EndDate" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TotalAmount" class="form-label">Tổng tiền (đ)</label>
                                <input asp-for="TotalAmount" class="form-control" type="number" />
                                <span asp-validation-for="TotalAmount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ProductId" class="form-label">Sản phẩm</label>
                                <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId"></select>
                                <span asp-validation-for="ProductId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="RenterId" class="form-label">Người thuê</label>
                                <select asp-for="RenterId" class="form-select" asp-items="ViewBag.RenterId"></select>
                                <span asp-validation-for="RenterId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-gradient px-4">
                                <i class="bi bi-check2-all me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
