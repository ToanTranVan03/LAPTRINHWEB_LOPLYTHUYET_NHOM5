@model TechShare.Models.Booking

@{
    ViewData["Title"] = "Xóa đơn hàng";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="warning-card">
                <div class="warning-header">
                    <i class="bi bi-exclamation-triangle-fill fs-1 d-block mb-2"></i>
                    <h4 class="mb-1">Xác nhận xóa đơn hàng</h4>
                    <p class="mb-0 opacity-75">Hành động này không thể hoàn tác!</p>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <small class="text-muted">Sản phẩm</small>
                            <p class="fw-bold mb-1">@Model.Product?.Name</p>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">Người thuê</small>
                            <p class="fw-bold mb-1">@(Model.Renter?.UserName ?? "N/A")</p>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">Ngày nhận</small>
                            <p class="fw-bold mb-0">@Model.StartDate.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">Ngày trả</small>
                            <p class="fw-bold mb-0">@Model.EndDate.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">Tổng tiền</small>
                            <p class="fw-bold mb-0 text-success">@Model.TotalAmount.ToString("N0") đ</p>
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex gap-2">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-gradient-danger flex-fill">
                            <i class="bi bi-trash3 me-1"></i> Xóa đơn hàng
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
