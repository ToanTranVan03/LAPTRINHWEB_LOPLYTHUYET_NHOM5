@model IEnumerable<TechShare.Models.Booking>

@{
    ViewData["Title"] = "Lịch sử thuê đồ";
}

<div class="container py-5">
    <h2 class="mb-4 text-primary"><i class="bi bi-clock-history"></i> Lịch sử đơn hàng của tôi</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Bạn chưa thuê món đồ nào cả. <a asp-controller="Home" asp-action="Index">Đi thuê ngay!</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle bg-white mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Ngày nhận</th>
                        <th>Ngày trả</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.Product?.Name</td>
                            <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-success fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                            <td>
                                @if(item.Status.ToString() == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                }
                                else if(item.Status.ToString() == "Approved")
                                {
                                    <span class="badge bg-success">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Xem chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>