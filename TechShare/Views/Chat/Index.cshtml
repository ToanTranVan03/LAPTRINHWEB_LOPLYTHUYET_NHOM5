@{
    ViewData["Title"] = "Tin nhắn";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var chatUsers = ViewBag.ChatUsers as List<TechShare.Models.ApplicationUser>;
    var activeUserId = ViewBag.ActiveUserId as string;
    var messages = ViewBag.Messages as List<TechShare.Models.ChatMessage>;
}

<style>
    .chat-container { height: calc(100vh - 180px); border-radius: 12px; overflow: hidden; }
    .chat-users-list { overflow-y: auto; height: 100%; border-right: 1px solid #dee2e6; }
    .chat-user-item { padding: 15px; border-bottom: 1px solid #dee2e6; cursor: pointer; transition: background 0.3s; }
    .chat-user-item:hover, .chat-user-item.active { background-color: rgba(99, 102, 241, 0.1); }
    .chat-messages { height: calc(100% - 130px); overflow-y: auto; padding: 20px; background-color: #f8f9fa; }
    .chat-message { max-width: 70%; margin-bottom: 15px; border-radius: 15px; padding: 10px 15px; position: relative; }
    .msg-sent {
        background: var(--gradient-main, linear-gradient(135deg, #667eea 0%, #764ba2 100%));
        color: #fff;
        margin-left: auto;
        border-bottom-right-radius: 0;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.25);
    }
    .msg-sent .msg-time {
        color: rgba(255, 255, 255, 0.9);
    }
    .msg-received { background: white; color: #333; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border-bottom-left-radius: 0; }
    .msg-time { font-size: 0.75rem; opacity: 0.7; margin-top: 5px; text-align: right; }
</style>

<div class="container py-4">
    <div class="row chat-container bg-white shadow-sm border">
        
        <!-- Left Sidebar: Users -->
        <div class="col-md-4 p-0 chat-users-list bg-light">
            <div class="p-3 border-bottom bg-white sticky-top">
                <h5 class="mb-0 fw-bold"><i class="bi bi-chat-dots me-2"></i> Trò chuyện</h5>
            </div>
            
            @if (chatUsers != null && chatUsers.Any())
            {
                foreach (var user in chatUsers)
                {
                    <a href="@Url.Action("Index", new { userId = user.Id })" class="text-decoration-none text-dark d-block">
                        <div class="chat-user-item d-flex align-items-center @(user.Id == activeUserId ? "active" : "")">
                            <div class="flex-shrink-0">
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(user.FullName ?? user.UserName)&background=random" 
                                     alt="@user.FullName" class="rounded-circle" width="50" height="50">
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="mb-0 fw-bold">@user.FullName</h6>
                                <small class="text-muted text-truncate d-inline-block" style="max-width: 150px;">
                                    @(user.Email)
                                </small>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-inbox fs-1 mb-2"></i>
                    <p>Chưa có hộp thoại nào</p>
                </div>
            }
        </div>

        <!-- Right Side: Chat Window -->
        <div class="col-md-8 p-0 d-flex flex-column h-100 position-relative">
            @if (!string.IsNullOrEmpty(activeUserId))
            {
                var activeUserModel = chatUsers?.FirstOrDefault(u => u.Id == activeUserId);
                
                <!-- Chat Header -->
                <div class="p-3 border-bottom d-flex align-items-center bg-white shadow-sm" style="z-index: 10;">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(activeUserModel?.FullName ?? "User")&background=random" 
                         class="rounded-circle me-3" width="45" height="45">
                    <div>
                        <h6 class="mb-0 fw-bold">@activeUserModel?.FullName</h6>
                        <small class="text-success"><i class="bi bi-circle-fill" style="font-size: 8px;"></i> Online</small>
                    </div>
                </div>

                <!-- Chat Messages Area -->
                <div class="chat-messages flex-grow-1" id="chatArea">
                    @if (messages != null)
                    {
                        foreach (var msg in messages)
                        {
                            var isSent = msg.SenderId == currentUserId;
                            <div class="chat-message @(isSent ? "msg-sent" : "msg-received")">
                                <div>@msg.Message</div>
                                <div class="msg-time">@msg.SentAt.ToString("HH:mm")</div>
                            </div>
                        }
                    }
                </div>

                <!-- Chat Input Frame -->
                <div class="p-3 bg-white border-top">
                    <div class="input-group">
                        <input type="text" id="messageInput" class="form-control" placeholder="Nhập tin nhắn của bạn..." autocomplete="off">
                        <button id="sendButton" class="btn btn-gradient px-4">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </div>

                <input type="hidden" id="receiverId" value="@activeUserId" />
                <input type="hidden" id="currentUserId" value="@currentUserId" />
            }
            else
            {
                <div class="d-flex w-100 h-100 justify-content-center align-items-center text-center text-muted flex-column bg-light">
                    <i class="bi bi-chat-square-text fs-1 mb-3"></i>
                    <h5>Chọn một cuộc trò chuyện để bắt đầu</h5>
                    <p>Hoặc liên hệ với người bán từ trang chi tiết sản phẩm.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        $(document).ready(function () {
            var chatArea = document.getElementById("chatArea");
            if (chatArea) {
                chatArea.scrollTop = chatArea.scrollHeight;
            }

            var receiverInput = document.getElementById("receiverId");
            var currentUserInput = document.getElementById("currentUserId");
            var activeReceiverId = receiverInput ? receiverInput.value : "";
            var currentUserId = currentUserInput ? currentUserInput.value : "";

            var connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();

            function appendMessage(messageClass, message, time) {
                if (!chatArea) {
                    return;
                }

                var msgDiv = $('<div class="chat-message ' + messageClass + '"></div>')
                    .append($('<div></div>').text(message))
                    .append($('<div class="msg-time"></div>').text(time));

                $('#chatArea').append(msgDiv);
                chatArea.scrollTop = chatArea.scrollHeight;
            }

            connection.on("ReceiveMessage", function (senderId, message, time) {
                if (!chatArea) {
                    return;
                }

                if (senderId === currentUserId) {
                    appendMessage("msg-sent", message, time);
                    $('#messageInput').val('').focus();
                    return;
                }

                if (senderId === activeReceiverId) {
                    appendMessage("msg-received", message, time);
                    return;
                }

                var toastHtml = `
                    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
                        <div class="toast show animate__animated animate__fadeInUp bg-white" data-bs-delay="5000">
                            <div class="toast-header border-bottom-0 text-primary">
                                <i class="bi bi-chat-dots-fill me-2"></i>
                                <strong class="me-auto">Tin nhắn mới</strong>
                                <small>${time}</small>
                                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
                            </div>
                            <div class="toast-body pt-0 text-dark">
                                Bạn có tin nhắn mới từ người dùng khác. <a href="/Chat/Index?userId=${senderId}">Xem ngay</a>
                            </div>
                        </div>
                    </div>`;

                $('body').append(toastHtml);
            });

            connection.start().catch(function (err) {
                console.error(err.toString());
            });

            $('#sendButton').click(async function () {
                var receiverId = $('#receiverId').val();
                var message = $('#messageInput').val().trim();

                if (!receiverId || message === "") {
                    return;
                }

                try {
                    await connection.invoke("SendMessage", receiverId, message);
                } catch (err) {
                    console.error(err.toString());
                    alert("Không thể gửi tin nhắn. Vui lòng thử lại.");
                }
            });

            $('#messageInput').keypress(function (e) {
                if (e.which == 13) {
                    $('#sendButton').click();
                }
            });
        });
    </script>
}

