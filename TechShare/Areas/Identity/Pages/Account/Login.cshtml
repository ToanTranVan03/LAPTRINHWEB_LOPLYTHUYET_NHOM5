@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card-premium p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="mb-3" style="font-size: 3rem;">
                        <i class="bi bi-box-arrow-in-right" style="background: var(--gradient-main); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"></i>
                    </div>
                    <h2 class="fw-bold mb-1">Đăng nhập</h2>
                    <p class="text-muted">Chào mừng bạn quay trở lại TechShare</p>
                </div>

                <form id="account" method="post" class="form-premium">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">
                            <i class="bi bi-envelope me-1" style="color: var(--primary);"></i> Email
                        </label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="you@email.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">
                            <i class="bi bi-lock me-1" style="color: var(--primary);"></i> Mật khẩu
                        </label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label asp-for="Input.RememberMe" class="form-check-label text-muted small">
                                Ghi nhớ đăng nhập
                            </label>
                        </div>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-gradient btn-lg w-100 mb-3">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                    </button>

                    <div class="text-center">
                        <span class="text-muted">Chưa có tài khoản?</span>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold" style="color: var(--primary);">
                            Đăng ký miễn phí
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            if ("geolocation" in navigator) {
                // Yêu cầu quyền vị trí khi vào trang đăng nhập
                navigator.geolocation.getCurrentPosition(function(position) {
                    var lat = position.coords.latitude;
                    var lng = position.coords.longitude;
                    // Lưu vào cookie 7 ngày
                    document.cookie = "user_lat=" + lat + ";path=/;max-age=" + (7*24*60*60);
                    document.cookie = "user_lng=" + lng + ";path=/;max-age=" + (7*24*60*60);
                }, function(error) {
                    console.log("Người dùng từ chối cấp quyền vị trí.");
                });
            }
        });
    </script>
}
