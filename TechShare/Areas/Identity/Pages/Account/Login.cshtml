@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <i class="bi bi-person-circle display-4" style="background: linear-gradient(135deg, #8A2BE2 0%, #4B0082 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                    </div>
                    <h2 class="fw-bold mb-1" style="color: #333;">Đăng nhập</h2>
                    <p class="text-muted">Chào mừng bạn quay trở lại TechShare</p>
                </div>

                <form id="account" method="post">
                    
                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success rounded-3 text-center mb-3 shadow-sm border-0">
                            <i class="bi bi-check-circle-fill me-1"></i> @Html.Raw(TempData["StatusMessage"])
                        </div>
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control rounded-3 border-secondary border-opacity-25" autocomplete="username" placeholder="Ví dụ: you@email.com" />
                        <label asp-for="Input.Email" class="text-muted">
                            <i class="bi bi-envelope-fill me-1" style="color: #8A2BE2;"></i> Email của bạn
                        </label>
                        <span asp-validation-for="Input.Email" class="text-danger small px-2"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input asp-for="Input.Password" class="form-control rounded-3 border-secondary border-opacity-25 pe-5" autocomplete="current-password" placeholder="Nhập mật khẩu của bạn" id="loginPassword" />
                        <label asp-for="Input.Password" class="text-muted">
                            <i class="bi bi-shield-lock-fill me-1" style="color: #8A2BE2;"></i> Mật khẩu
                        </label>
                        <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 fs-5 text-muted toggle-password" data-target="loginPassword" style="cursor: pointer; z-index: 10;" title="Hiện/Ẩn mật khẩu"></i>
                        <span asp-validation-for="Input.Password" class="text-danger small px-2"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input shadow-none" type="checkbox" asp-for="Input.RememberMe" id="rememberMe">
                            <label class="form-check-label text-muted small user-select-none" for="rememberMe">Ghi nhớ tôi</label>
                        </div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="small fw-bold text-decoration-none" style="color: #8A2BE2;">Quên mật khẩu?</a>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-lg w-100 text-white shadow rounded-3 mb-4 fw-bold" style="background: linear-gradient(135deg, #8A2BE2 0%, #4B0082 100%); border: none;">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập
                    </button>

                    <div class="text-center">
                        <span class="text-muted">Chưa có tài khoản?</span>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none ms-1" style="color: #8A2BE2;">
                            Đăng ký miễn phí
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // 1. TÍNH NĂNG ẨN/HIỆN MẬT KHẨU
            $('.toggle-password').click(function() {
                let targetId = $(this).data('target');
                let input = $('#' + targetId);
                let type = input.attr('type') === 'password' ? 'text' : 'password';
                input.attr('type', type);
                $(this).toggleClass('bi-eye-slash bi-eye');
            });

            // 2. TÍNH NĂNG GHI NHỚ EMAIL (TRICK CHO ĐỒ ÁN)
            // Kiểm tra xem trước đó có lưu email nào không
            var savedEmail = localStorage.getItem('techshare_saved_email');
            if (savedEmail) {
                $('#Input_Email').val(savedEmail); // Tự động điền email
                $('#rememberMe').prop('checked', true); // Bật sẵn nút công tắc lên
            }

            // Bắt sự kiện khi bấm nút Đăng nhập
            $('#account').submit(function() {
                if ($('#rememberMe').is(':checked')) {
                    // Nếu công tắc đang bật -> Lưu email vào bộ nhớ máy
                    localStorage.setItem('techshare_saved_email', $('#Input_Email').val());
                } else {
                    // Nếu công tắc tắt -> Xóa email khỏi bộ nhớ
                    localStorage.removeItem('techshare_saved_email');
                }
            });

            // 3. LOGIC LẤY VỊ TRÍ
            if ("geolocation" in navigator) {
                navigator.geolocation.getCurrentPosition(function(position) {
                    var lat = position.coords.latitude;
                    var lng = position.coords.longitude;
                    document.cookie = "user_lat=" + lat + ";path=/;max-age=" + (7*24*60*60);
                    document.cookie = "user_lng=" + lng + ";path=/;max-age=" + (7*24*60*60);
                }, function(error) {
                    console.log("Người dùng từ chối cấp quyền vị trí.");
                });
            }
        });
    </script>
}