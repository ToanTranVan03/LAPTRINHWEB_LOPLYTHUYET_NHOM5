@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card-premium p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="mb-3" style="font-size: 3rem;">
                        <i class="bi bi-person-plus-fill" style="background: var(--gradient-main); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"></i>
                    </div>
                    <h2 class="fw-bold mb-1">Đăng ký tài khoản</h2>
                    <p class="text-muted">Tạo tài khoản TechShare miễn phí để bắt đầu thuê & mua bán thiết bị</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-premium">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label">
                            <i class="bi bi-person me-1" style="color: var(--primary);"></i> Họ và tên <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.FullName" class="form-control" placeholder="Nhập họ và tên đầy đủ" />
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">
                            <i class="bi bi-envelope me-1" style="color: var(--primary);"></i> Email <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="you@email.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">
                            <i class="bi bi-lock me-1" style="color: var(--primary);"></i> Mật khẩu <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Tối thiểu 3 ký tự" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label">
                            <i class="bi bi-lock-fill me-1" style="color: var(--primary);"></i> Xác nhận mật khẩu <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Nhập lại mật khẩu" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-gradient btn-lg w-100 mb-3">
                        <i class="bi bi-person-check me-1"></i> Đăng ký
                    </button>

                    <div class="text-center">
                        <span class="text-muted">Đã có tài khoản?</span>
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold" style="color: var(--primary);">
                            Đăng nhập ngay
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
