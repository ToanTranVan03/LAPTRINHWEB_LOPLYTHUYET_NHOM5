@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Mật khẩu mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <i class="bi bi-shield-lock display-4" style="background: linear-gradient(135deg, #8A2BE2 0%, #4B0082 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                    </div>
                    <h2 class="fw-bold mb-2" style="color: #333;">Mật khẩu mới</h2>
                    <p class="text-muted small">Vui lòng nhập email xác nhận và mật khẩu mới của bạn.</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>
                    
                    <input asp-for="Input.Code" type="hidden" />

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control rounded-3 border-secondary border-opacity-25" autocomplete="username" placeholder="you@email.com" />
                        <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope-fill me-1" style="color: #8A2BE2;"></i> Email xác nhận</label>
                        <span asp-validation-for="Input.Email" class="text-danger small px-2"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input asp-for="Input.Password" class="form-control rounded-3 border-secondary border-opacity-25 pe-5" autocomplete="new-password" placeholder="Mật khẩu mới" id="resetPass" />
                        <label asp-for="Input.Password" class="text-muted"><i class="bi bi-key-fill me-1" style="color: #8A2BE2;"></i> Mật khẩu mới</label>
                        <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 fs-5 text-muted toggle-password" data-target="resetPass" style="cursor: pointer; z-index: 10;"></i>
                        <span asp-validation-for="Input.Password" class="text-danger small px-2"></span>
                    </div>

                    <div class="form-floating mb-4 position-relative">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-3 border-secondary border-opacity-25 pe-5" autocomplete="new-password" placeholder="Xác nhận mật khẩu" id="resetConfirmPass" />
                        <label asp-for="Input.ConfirmPassword" class="text-muted"><i class="bi bi-check-circle-fill me-1" style="color: #8A2BE2;"></i> Xác nhận mật khẩu</label>
                        <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 fs-5 text-muted toggle-password" data-target="resetConfirmPass" style="cursor: pointer; z-index: 10;"></i>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small px-2"></span>
                    </div>

                    <button type="submit" class="btn btn-lg w-100 text-white shadow rounded-3 mb-4 fw-bold" style="background: linear-gradient(135deg, #8A2BE2 0%, #4B0082 100%); border: none;">
                        <i class="bi bi-check2-all me-2"></i> Lưu mật khẩu mới
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            $('.toggle-password').click(function() {
                let targetId = $(this).data('target');
                let input = $('#' + targetId);
                let type = input.attr('type') === 'password' ? 'text' : 'password';
                input.attr('type', type);
                $(this).toggleClass('bi-eye-slash bi-eye');
            });
        });
    </script>
}