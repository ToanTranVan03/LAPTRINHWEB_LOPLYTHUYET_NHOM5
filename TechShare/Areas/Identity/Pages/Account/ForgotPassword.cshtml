@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu?";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <i class="bi bi-key display-4" style="background: linear-gradient(135deg, #8A2BE2 0%, #4B0082 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                    </div>
                    <h2 class="fw-bold mb-2" style="color: #333;">Khôi phục mật khẩu</h2>
                    <p class="text-muted small">Nhập địa chỉ email của bạn, chúng tôi sẽ gửi liên kết để đặt lại mật khẩu an toàn.</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control rounded-3 border-secondary border-opacity-25" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-muted">
                            <i class="bi bi-envelope-fill me-1" style="color: #8A2BE2;"></i> Email đăng ký
                        </label>
                        <span asp-validation-for="Input.Email" class="text-danger small px-2"></span>
                    </div>

                    <button type="submit" class="btn btn-lg w-100 text-white shadow rounded-3 mb-4 fw-bold" style="background: linear-gradient(135deg, #8A2BE2 0%, #4B0082 100%); border: none;">
                        <i class="bi bi-send-fill me-2"></i> Gửi link khôi phục
                    </button>

                    <div class="text-center mt-2">
                        <a asp-page="./Login" class="text-muted text-decoration-none fw-semibold hover-primary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại đăng nhập
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}